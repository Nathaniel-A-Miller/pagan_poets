        {
          "verse_index": 0,
          "text": "تُكَذِّبُ دِينَ اللهِ وَالْمَرْءَ أَحْمَداً  لَعَمْرِي الَّذِي أَمْناكَ أَنْ بِئْسَ ما يُمْنِي"
        },
        {
          "verse_index": 1,
          "text": "حَباكَ حَنيفَ آخِرَ الدَّهْرِ طَعْنَةً  أَبا عَفَكٍ خُذْها عَلَى كِبَرِ السِّنِّ"
        }
      ]
    }
  ]
