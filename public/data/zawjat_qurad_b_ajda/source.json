      "verses": [
        {
          "verse_index": 0,
          "text": "أَيا عَيْنُ بَكِّي لِي قُرادَ بْنَ أَجْدَعا  رَهِيناً لِقَتْلٍ لا رَهِيناً مُوَدَّعا"
        },
        {
          "verse_index": 1,
          "text": "أَتَتْهُ الْمَنايا بَغْتَةً دُونَ قَوْمِهِ  فَأَمْسَى أَسِيراً حاضِرَ الْبَيْتِ أَضْرَعا"
        }
      ]
    }
  ]
