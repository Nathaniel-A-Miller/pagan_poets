{
  "poet": {
    "name_ar": "الاغلب العجلي",
    "name_en": "Al-Aghlab al-ʿIjlī",
    "tribe": "ʿIjl (Bakr b. Wāʾil)",
    "region": "Iraq / Euphrates",
    "chronological_layer": "mukhaḍramūn",
    "gender": "male",
    "number_of_lines": 126,
    "metadata_notes": ""
  },
  "poems": [
    {
      "poem_index": 0,
      "poem_id": "al-aghlab_al-ʿijlī_000",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "الحلمُ بعدَ الجهلِ قد يؤوبُ  وفي الزمانِ عَجَبٌ عجيبُ"
        },
        {
          "verse_index": 1,
          "text": "وعبرةٌ لو ينفعُ التجريبُ  واللبُ لا يشقى به اللبيبُ"
        },
        {
          "verse_index": 2,
          "text": "والمرءُ مُحصىً سعيه مرقوبُ  يهرمُ ان تعتاقُهُ شعوبُ"
        },
        {
          "verse_index": 3,
          "text": "وكلُّ أقصى ربضه قريبُ"
        }
      ]
    },
    {
      "poem_index": 1,
      "poem_id": "al-aghlab_al-ʿijlī_001",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "جاريةٌ من قيس ابنِ ثَعلَبَه  كَريمةٌ اخوالها والعَصَبه"
        },
        {
          "verse_index": 1,
          "text": "قبّاءُ ذات سُرَّةٍ مقعّبَه  كأنّها حُقّةُ مِسك مُذهبه"
        },
        {
          "verse_index": 2,
          "text": "ممكورةُ الأعلى رِداحُ الحجبَه  كأَنّها حليةُ سيف مذهبه"
        },
        {
          "verse_index": 3,
          "text": "اهوى لها شيخٌ شديدُ العصبَه  خاظي البضيع ايره كالخشبَه"
        },
        {
          "verse_index": 4,
          "text": "فضَرَبت بالوَدِّ فوقَ الارنبه  ثم انثنت به فويقَ الرقبه"
        },
        {
          "verse_index": 5,
          "text": "فانصرفَت وهي حصانٌ مُغصَبَه  فأعلنت بصوتها أن يا أبه"
        },
        {
          "verse_index": 6,
          "text": "كلُّ فتاةٍ بأبيها مُعجَبَه"
        }
      ]
    },
    {
      "poem_index": 2,
      "poem_id": "al-aghlab_al-ʿijlī_002",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إذا لقيت واحداً من ضبّه  عشراً في سواء السّبه"
        },
        {
          "verse_index": 1,
          "text": "غمزَ العباديِّ عفاصَ الدَّبّه"
        }
      ]
    },
    {
      "poem_index": 3,
      "poem_id": "al-aghlab_al-ʿijlī_003",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "على قلاصٍ يعملاتٍ قَبِّ  وهَنَّ يمصعنَ امتصاع الأظبِ"
        },
        {
          "verse_index": 1,
          "text": "مُتّسِقاتٍ كضلوعِ الجنبِ"
        }
      ]
    },
    {
      "poem_index": 4,
      "poem_id": "al-aghlab_al-ʿijlī_004",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "وهو إذا جرجر بعد الهبِّ  جرجر في حنجرَةِ كالحُبِّ"
        },
        {
          "verse_index": 1,
          "text": "وهامةٍ كالمرجلِ المنكب"
        }
      ]
    },
    {
      "poem_index": 5,
      "poem_id": "al-aghlab_al-ʿijlī_005",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "كأنَّ صوتَ نابهِ الأَذَبِّ  صريفُ خطّافٍ بَقَعوٍ قَعبِ"
        },
        {
          "verse_index": 1,
          "text": "ماضٍ الركب مذ لعبّ"
        }
      ]
    },
    {
      "poem_index": 6,
      "poem_id": "al-aghlab_al-ʿijlī_006",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "ما زِلت يوم البين الوي صَلبي  والرأسَ حتى صرتُ مّل الأغلب"
        }
      ]
    },
    {
      "poem_index": 7,
      "poem_id": "al-aghlab_al-ʿijlī_007",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "كمذلعبّ الفرسك المهالب"
        }
      ]
    },
    {
      "poem_index": 8,
      "poem_id": "al-aghlab_al-ʿijlī_008",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "تخطو على خَدَلّجِ الأنبوبِ"
        }
      ]
    },
    {
      "poem_index": 9,
      "poem_id": "al-aghlab_al-ʿijlī_009",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أشرفَ ثدياها على التريُّبِ  لم يعدوا التفليك في النّتوُّبِ"
        }
      ]
    },
    {
      "poem_index": 10,
      "poem_id": "al-aghlab_al-ʿijlī_010",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "رُبَّ غُلامٍ قَد جرى في فِقرَته  ماءَ الشبابِ عنفوانَ سَنبتِه"
        },
        {
          "verse_index": 1,
          "text": "أنعَظَ حتى اشتدَّ سَمُّ سُمّتِه"
        }
      ]
    },
    {
      "poem_index": 11,
      "poem_id": "al-aghlab_al-ʿijlī_011",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "قَد عَرَفتني سَرحَتي فأطّتِ  وَقَد شَمِطتُ بعدَها واشمَطّتِ"
        }
      ]
    },
    {
      "poem_index": 12,
      "poem_id": "al-aghlab_al-ʿijlī_012",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "كم بَعدَها مِن وَرطَةٍ ووَرطَة  دافعها ذو العرش بعد وَبطَتي"
        },
        {
          "verse_index": 1,
          "text": "ودافَعَ المكروةَ بَعدَ قَعطَتي"
        }
      ]
    },
    {
      "poem_index": 13,
      "poem_id": "al-aghlab_al-ʿijlī_013",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "وتارة يكدُّ أن لم يُجرَح  عَرعَرةَ المتكِ وكينِ المشدَح"
        }
      ]
    },
    {
      "poem_index": 14,
      "poem_id": "al-aghlab_al-ʿijlī_014",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "تَخالُهُ مِن كَرفِهِنَّ كالحا  وافتَرَّ صاباً ونشُوقاً مالحا"
        }
      ]
    },
    {
      "poem_index": 15,
      "poem_id": "al-aghlab_al-ʿijlī_015",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أَبو عِيالٍ يَكدَحُ المَكادِحا"
        }
      ]
    },
    {
      "poem_index": 16,
      "poem_id": "al-aghlab_al-ʿijlī_016",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أرجزاً تُريدُ أم قَصِيدا  لَقَد سألت هَيِّناً مَوجودا"
        }
      ]
    },
    {
      "poem_index": 17,
      "poem_id": "al-aghlab_al-ʿijlī_017",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "لا يُحسِنُ التحميضَ إلا سَردا"
        }
      ]
    },
    {
      "poem_index": 18,
      "poem_id": "al-aghlab_al-ʿijlī_018",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "فَمَا تُربُ أثرَى لو جَمَعتَ تُرابَها  بأكثر مِن حَيّي نزَارٍ على العَدِّ"
        }
      ]
    },
    {
      "poem_index": 19,
      "poem_id": "al-aghlab_al-ʿijlī_019",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "يا ربَّ حَربٍ ثَرَّةِ الأَحلافِ"
        }
      ]
    },
    {
      "poem_index": 20,
      "poem_id": "al-aghlab_al-ʿijlī_020",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "نحنُ بنو عجلٍ اذا احمَرَّ الحَدَق  ولَبِسَ الأَبطالُ ماذيَّ الحَلَق"
        },
        {
          "verse_index": 1,
          "text": "وثارَ للحربِ عجاج فَسَمَق  نحمي الذمار حين لا يحمي الفَرِق"
        }
      ]
    },
    {
      "poem_index": 21,
      "poem_id": "al-aghlab_al-ʿijlī_021",
      "meter": "بسيط",
      "verses": [
        {
          "verse_index": 0,
          "text": "قال لها في بعضِ ما يُسَطِّرُه  وهي تنادي تَحتَهُ وتذمره"
        },
        {
          "verse_index": 1,
          "text": "وهو شديدٌ لفظُهُ وذَكرُه  مَن يشتري سيفي وهذا أَثَرُه"
        }
      ]
    },
    {
      "poem_index": 22,
      "poem_id": "al-aghlab_al-ʿijlī_022",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "المرءُ تَوَّاقٌ الى ما لم يَنَل  والموت يتلوه ويلهيه الأَمَل"
        }
      ]
    },
    {
      "poem_index": 23,
      "poem_id": "al-aghlab_al-ʿijlī_023",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "وشَرُّ ما رامَ امرؤٌ ما لم يَنَل"
        }
      ]
    },
    {
      "poem_index": 24,
      "poem_id": "al-aghlab_al-ʿijlī_024",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "ما إن رأينا ملكا أَغارا  أكثرَ منهُ قِرَةً وقارا"
        },
        {
          "verse_index": 1,
          "text": "وفارساً يَستَلِبُ الهجارا"
        }
      ]
    },
    {
      "poem_index": 25,
      "poem_id": "al-aghlab_al-ʿijlī_025",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فالويلُ لو ينجيه قول الويل  يسعى بيدٍ وذيل كذا"
        }
      ]
    },
    {
      "poem_index": 26,
      "poem_id": "al-aghlab_al-ʿijlī_026",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إذا رأوا حَومَ المنا لم يرحلوا  اخرى ولم ينبوا ولم يهللوا"
        },
        {
          "verse_index": 1,
          "text": "يا ليتني اسالي يفعَلُ  ضرباً وطعناً او يموتَ الأعجلُ"
        }
      ]
    },
    {
      "poem_index": 27,
      "poem_id": "al-aghlab_al-ʿijlī_027",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "عهدي بقيس وهي من خير الأُمم  لا يطأون قدماً على قَدَم"
        }
      ]
    },
    {
      "poem_index": 28,
      "poem_id": "al-aghlab_al-ʿijlī_028",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "يا ربَّ شيخٍ مِن لَكيزٍ كَهكَمِ  قَلّصَ عن ذاتِ شبابٍ خِدلم"
        }
      ]
    },
    {
      "poem_index": 29,
      "poem_id": "al-aghlab_al-ʿijlī_029",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فَبَصَرَت بَعَزَبٍ مُلأمِ  فَأَخذت من رادنٍ وكركم"
        }
      ]
    },
    {
      "poem_index": 30,
      "poem_id": "al-aghlab_al-ʿijlī_030",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إن قابل العرسَ تشكّى وخَضَم"
        }
      ]
    },
    {
      "poem_index": 31,
      "poem_id": "al-aghlab_al-ʿijlī_031",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "بعد شميم شاغفٍ وفَغمِ"
        }
      ]
    },
    {
      "poem_index": 32,
      "poem_id": "al-aghlab_al-ʿijlī_032",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "وواجهتهُ بعظيم الحجم  أبيضَ رابي الربلتين ضَخمِ"
        }
      ]
    },
    {
      "poem_index": 33,
      "poem_id": "al-aghlab_al-ʿijlī_033",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "خوارسٌ وحرشفٌ كالدِّيمِ  لا تتأنّى حَذَرَ الكُلُومِ"
        }
      ]
    },
    {
      "poem_index": 34,
      "poem_id": "al-aghlab_al-ʿijlī_034",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "ينفيهمُ عن كَلأٍ غِمّيمِ  ضَربَ القُدار نيقةَ القِدِّيمِ"
        },
        {
          "verse_index": 1,
          "text": "يفرق بين النفس والنسيمِ"
        }
      ]
    },
    {
      "poem_index": 35,
      "poem_id": "al-aghlab_al-ʿijlī_035",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إنّا على التشواقِ منا والحزَن  مما نَمُدُّ للمطيِّ المستفن"
        },
        {
          "verse_index": 1,
          "text": "نسوقها سَنّاً وبعضُ السوقِ سَن  حتى نراها وكأَنَّ وكأَن"
        },
        {
          "verse_index": 2,
          "text": "أعناقُها ملزَّزاتٌ في قَرَن  حتى إذا قضوا لبُاناتِ الشجن"
        },
        {
          "verse_index": 3,
          "text": "وكلُّ حاجٍ لفلانٍ او لهن  قاموا فَشدُّوها لما يشقى الأرن"
        },
        {
          "verse_index": 4,
          "text": "ورحلوها رحلةً فيها رعن  حتى أنخناها الى مَنٍّ ومَن"
        }
      ]
    },
    {
      "poem_index": 36,
      "poem_id": "al-aghlab_al-ʿijlī_036",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فَبِتُ أمريها وادنو للثّنَن  بقازح الجلزمتينِ كالرسن"
        }
      ]
    },
    {
      "poem_index": 37,
      "poem_id": "al-aghlab_al-ʿijlī_037",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "ليس مِنَ اللائي تُسوَّى بالغَمَن"
        }
      ]
    },
    {
      "poem_index": 38,
      "poem_id": "al-aghlab_al-ʿijlī_038",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "قد علموا يومَ خُنابزينا  إذ مالتِ الأَحياءُ مقبلينا"
        },
        {
          "verse_index": 1,
          "text": "إنا بنو عِجلٍ إذا لقينا  نمنع مِنّا حدَّ مَن يَلينا"
        },
        {
          "verse_index": 2,
          "text": "ما منه قبحُ فعله يرينا  نحن منعنا جوف والغينا"
        },
        {
          "verse_index": 3,
          "text": "وقد تدلّى عِنبا وتينا  أما الجباياتِ فقد غشينا"
        },
        {
          "verse_index": 4,
          "text": "وقد ولجنا جوف مُولِعينا  بفاقِراتٍ تحتَ فاقرينا"
        },
        {
          "verse_index": 5,
          "text": "يتركنَ من ناحيةٍ رهينا  نقارعُ السنينَ عن بنينا"
        },
        {
          "verse_index": 6,
          "text": "الغمرات حتى ينجلينا  ثَمّتَ يَذهبنَ ولا يَجينا"
        },
        {
          "verse_index": 7,
          "text": "لو كُنَّ صُمَّ جندلٍ يلينا"
        }
      ]
    },
    {
      "poem_index": 39,
      "poem_id": "al-aghlab_al-ʿijlī_039",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فانطح بفودي رأسه الأركانا"
        }
      ]
    },
    {
      "poem_index": 40,
      "poem_id": "al-aghlab_al-ʿijlī_040",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أغرُّ من خيلِ بني ميمونِ  بين الجميلياتِ والحرون"
        }
      ]
    },
    {
      "poem_index": 41,
      "poem_id": "al-aghlab_al-ʿijlī_041",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "نحنُ جَلَبنا الخيل مِن غَوَّارِ  شوازبا يَقذِفنَ بالأَمهارِ"
        },
        {
          "verse_index": 1,
          "text": "تَردي بنا طوامِحَ الأَبصَارِ  يحملنَ تَحتَ الرَّهَج المُثارِ"
        },
        {
          "verse_index": 2,
          "text": "كُلَّ كريم في الوغى مهصارِ  أَهلِ النّدَى والحِلمِ والوَقارِ"
        },
        {
          "verse_index": 3,
          "text": "كم فيهم من بطلٍ مِغوَارِ  أَشعَث قَد ليحَ مِنَ الغوارِ"
        },
        {
          "verse_index": 4,
          "text": "تَنشَقُّ عَنهُ ظُلَمُ الغِمَارِ  تَمَزُّقَ الليلِ عنِ النّهَارِ"
        }
      ]
    },
    {
      "poem_index": 42,
      "poem_id": "al-aghlab_al-ʿijlī_042",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فيا شمالي زاوجي يميني  وإن كرِهتِ عشرتي فبيني"
        },
        {
          "verse_index": 1,
          "text": "فإنما يُضنُّ بالضَّنينِ"
        }
      ]
    },
    {
      "poem_index": 43,
      "poem_id": "al-aghlab_al-ʿijlī_043",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إذا انجلى فاثور عين الشمس"
        }
      ]
    },
    {
      "poem_index": 44,
      "poem_id": "al-aghlab_al-ʿijlī_044",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أقبلَ في ثوبٍ معافريِّ  بين اختلاطِ الليلِ والعشيِّ"
        },
        {
          "verse_index": 1,
          "text": "ماضٍ إذا ما همَّ بالمضيِّ  قال لها هل لكِ يا تا في"
        },
        {
          "verse_index": 2,
          "text": "قالت له ما أنتَ بالمرضي"
        }
      ]
    },
    {
      "poem_index": 45,
      "poem_id": "al-aghlab_al-ʿijlī_045",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "كأنَّ تحتَ خُفِّها الوهاصِ  ميظبَ أكم نِيطَ بالملاصِ"
        }
      ]
    },
    {
      "poem_index": 46,
      "poem_id": "al-aghlab_al-ʿijlī_046",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "صَلتَ الجبينِ ظاهِرَ الشيراصِ"
        }
      ]
    },
    {
      "poem_index": 47,
      "poem_id": "al-aghlab_al-ʿijlī_047",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "قد لقيت سَجاحِ من بعدِ العمى  تاح لها بعدكَ حِنزابٌ وزى"
        },
        {
          "verse_index": 1,
          "text": "مُلوَّحاً في العينِ مجلوزَ القَرَا  مثلَ الفنيقِ في شبابٍ قد أنى"
        },
        {
          "verse_index": 2,
          "text": "مِنَ اللجيميّين اصحابِ القُرى  ليسَ بذي واهنة ولا نسا"
        },
        {
          "verse_index": 3,
          "text": "نشا بخبزٍ وبلحمٍ ما اشتهى  حتى شتا ينتح ذفراهُ الندى"
        },
        {
          "verse_index": 4,
          "text": "خاظي البضيع لحمُهُ خظابظا  كأنمّا جُمِّعَ من لحم الخُصَى"
        },
        {
          "verse_index": 5,
          "text": "إذا تمطذى بين بُردَيه صَأى  كأنَّ عرقَ ايرهِ اذا ودى"
        },
        {
          "verse_index": 6,
          "text": "حبلَ عجوزٍ ضَفّرَت سبع قوى  يمشى على قوائمٍ له زكا"
        },
        {
          "verse_index": 7,
          "text": "يرفع وسطاهُنَّ من بردِ الندى  قالت متى كنت ابا الخير متى"
        },
        {
          "verse_index": 8,
          "text": "قال حديثاً لم يغيرني البِلى  ولم أُفارق خُلّةً لي عن قِلى"
        },
        {
          "verse_index": 9,
          "text": "فانتفشَت فَيشَتُهُ ذاتُ الشوى  كأنَّ في أجيادها سبع كُلى"
        },
        {
          "verse_index": 10,
          "text": "ما زال عنها بالحديثِ والمنى  والخُلُقُ السفسافُ يردي في الردى"
        },
        {
          "verse_index": 11,
          "text": "قال الا ترينَهُ قالت أرى  قال الا أُشيمُهُ قالت بلى"
        },
        {
          "verse_index": 12,
          "text": "فشامَ فيها مثلَ محراثِ الغضا  يقول لما غابَ فيها واستوى"
        },
        {
          "verse_index": 13,
          "text": "لمثلها كنتُ أُحسيكِ الحُسَا  يبرى لها كينا كأطرافِ النوى"
        },
        {
          "verse_index": 14,
          "text": "وقد تطلّت حين هَمَّ وادَّنى  من طيبِ مصانَ الذي كان اشترى"
        },
        {
          "verse_index": 15,
          "text": "تقذفُ عيناه بِعِلكِ المُصطَكى"
        }
      ]
    },
    {
      "poem_index": 48,
      "poem_id": "al-aghlab_al-ʿijlī_048",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "فهي على ما كان من نشاصِ  بظربٍ الأرضَ وبالدلاصِ"
        }
      ]
    },
    {
      "poem_index": 49,
      "poem_id": "al-aghlab_al-ʿijlī_049",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "قد سرني الشيخ الذي ساء الفتى  إذ لم يكن ما ضم امساد الغفى"
        }
      ]
    },
    {
      "poem_index": 50,
      "poem_id": "al-aghlab_al-ʿijlī_050",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أصبحت لا يحمل بعضي بعضي  منفهاً أروحُ مثلَ النقض"
        },
        {
          "verse_index": 1,
          "text": "طول الليالي أسرعت في نفضي  حنين طولي وطوين عرضي"
        },
        {
          "verse_index": 2,
          "text": "ثم انتحَينَ من عظامي مَخضي  أقعدنَني من بعدِ طولِ نَهضي"
        }
      ]
    },
    {
      "poem_index": 51,
      "poem_id": "al-aghlab_al-ʿijlī_051",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إذا تخازرت وما بي من خزر  ثم كسرتُ الطرف من غير صور"
        },
        {
          "verse_index": 1,
          "text": "وجدتني ألوي بعيدَ المستمر  احملُ ما حملتُ من خير وشر"
        },
        {
          "verse_index": 2,
          "text": "أبذا اذى بوذيت من كلبٍ ذكر  اسودَ فزّاحٍ يعوِّي في السحر"
        }
      ]
    },
    {
      "poem_index": 52,
      "poem_id": "al-aghlab_al-ʿijlī_052",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أعابرانِ نحنُ في العبّارِ  أم غابرانِ نحنُ في الغُبّار"
        }
      ]
    },
    {
      "poem_index": 53,
      "poem_id": "al-aghlab_al-ʿijlī_053",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "لو أنها لاقت غلاماً طائطا  ألقى عليها كَلكَلاً علابطا"
        }
      ]
    },
    {
      "poem_index": 54,
      "poem_id": "al-aghlab_al-ʿijlī_054",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "طَلسةُ شيخٍ أرسَحٍ زحَنقَفِ  له ثنايا مِثلُ حَبِّ القَلَفَ"
        },
        {
          "verse_index": 1,
          "text": "فبصرَت بناشئٍ مُهَفهَفِ"
        }
      ]
    },
    {
      "poem_index": 55,
      "poem_id": "al-aghlab_al-ʿijlī_055",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "أرجزاً تريدُ أم قريضا  أم هكذا بينهما تعريضا"
        },
        {
          "verse_index": 1,
          "text": "كلاهما أجيد مستريضا"
        }
      ]
    },
    {
      "poem_index": 56,
      "poem_id": "al-aghlab_al-ʿijlī_056",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إن سرَّكَ العزَّ فجخجخ بجثَم  أهلِ النباة والعديدِ والكرم"
        },
        {
          "verse_index": 1,
          "text": "جاؤوا بزَورَيهم وجئنا بالأَصَم  شيخ لنا كالليثِ من باقي إرم"
        },
        {
          "verse_index": 2,
          "text": "قد كدمَ الشيبُ قفاه فكدم  شيخ لنا معاودٍ ضَربَ البُهَم"
        },
        {
          "verse_index": 3,
          "text": "مؤيدِ الخُلقِ إذا هَمَّ عَزَم  يُمكِّنُ السيف إذا الرمحُ انفصم"
        },
        {
          "verse_index": 4,
          "text": "كهمّةِ الليث إذا الليث هَم  فدىَّ له من طالبٍ خالي وعم"
        },
        {
          "verse_index": 5,
          "text": "إذ ركبت ضبّةُ اعجازَ النّعَم  فلم تدع ساقاً لها ولا قَدَم"
        },
        {
          "verse_index": 6,
          "text": "ولّوا سلالاً واتقونا بالحُرَم  واستمطروها ديماً بعد دِيَم"
        },
        {
          "verse_index": 7,
          "text": "يوماً فجاءتهم شآبيب بدم  كانت تميم معشرا ذوي كرم"
        },
        {
          "verse_index": 8,
          "text": "غلصمة من الغلاصيم العظم  هل غيرُ غار صكَّ غاراً فانهزم"
        },
        {
          "verse_index": 9,
          "text": "قد قاتلوا لو ينفخون في فحم  وصبروا لو صبروا على أَمَم"
        }
      ]
    },
    {
      "poem_index": 57,
      "poem_id": "al-aghlab_al-ʿijlī_057",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "عند الصباحِ يحمدُ القومُ السُّرَى"
        }
      ]
    }
  ]
}