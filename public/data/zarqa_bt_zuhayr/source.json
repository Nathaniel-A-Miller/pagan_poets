      "meter": "كامل",
      "verses": [
        {
          "verse_index": 0,
          "text": "وَدِّعْ تِهامَةَ لا وَداعَ مُخالِقٍ  بِذِمامِهِ لَكِنْ قِلىً وَمَلامُ"
        },
        {
          "verse_index": 1,
          "text": "لا تُنْكِرِي هَجْراً مُقامَ غَرِيبَةٍ  لَنْ تَعْدَمِي مِنْ ظاعِنِينَ تِهامُ"
        }
      ]
    }
  ]
