      "verses": [
        {
          "verse_index": 0,
          "text": "إِنَّا بَنُو ثَعْلَبَةَ بْنِ مالِكِ  مُرَزَّأٌ أَخْيارُنا كَذَلِكِ"
        },
        {
          "verse_index": 1,
          "text": "مِنْ بَيْنِ مَقْتُولٍ وَبَيْنِ هالِكِ  وَلا يَكُونُ الرُّزْءُ إلَّا ذَلِكِ"
        }
      ]
    }
  ]
