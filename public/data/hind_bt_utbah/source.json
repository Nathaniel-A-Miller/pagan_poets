{
  "poet": {
    "name_ar": "هند بنت عتبة",
    "name_en": "Hind bt. ʿUtbah",
    "tribe": "Quraysh",
    "region": "Hijaz",
    "chronological_layer": "mukhaḍramūn",
    "gender": "female",
    "number_of_lines": 75,
    "metadata_notes": ""
  },
  "poems": [
    {
      "poem_index": 0,
      "poem_id": "hind_bt_ʿutbah_000",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "رجعت وفي نفسي بلابل جمة  وقد فاتني بعض الذي كان مطلبي"
        },
        {
          "verse_index": 1,
          "text": "من أصحاب بدر من قريش وغيرهم  بني هاشم منهم ومن أهل يثرب"
        },
        {
          "verse_index": 2,
          "text": "ولكنني قد نلت شيئاً ولم يكن  كما كنت أرجو في مسيري ومركبي"
        }
      ]
    },
    {
      "poem_index": 1,
      "poem_id": "hind_bt_ʿutbah_001",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "رجعت وفي نفسي بلابل جمة  وقد فاتني بعض الذي كان مطلبي"
        },
        {
          "verse_index": 1,
          "text": "من أصحاب بدر من قريش وغيرهم  بني هاشم منهم ومن أهل يثرب"
        },
        {
          "verse_index": 2,
          "text": "ولكنني قد نلت شيئاً ولم يكن  كما كنت أرجو في مسيري ومركبي"
        }
      ]
    },
    {
      "poem_index": 2,
      "poem_id": "hind_bt_ʿutbah_002",
      "meter": "متقارب",
      "verses": [
        {
          "verse_index": 0,
          "text": "أعيني جواداً بدمع سرب  على خير خندف لم ينقلب"
        },
        {
          "verse_index": 1,
          "text": "تداعى له رهطه غدوة  بنو هاشم وبنو المطلب"
        },
        {
          "verse_index": 2,
          "text": "يذيقونه حد أسيافهم  يعلونه بعد ما قد عطب"
        },
        {
          "verse_index": 3,
          "text": "يجرونه وعفير التراب  على وجهه عارياً قد سلب"
        },
        {
          "verse_index": 4,
          "text": "وكان لنا جبلاً راسياً  جميل المراة كثير العشب"
        },
        {
          "verse_index": 5,
          "text": "وأما بري فلم أعنه  فأوتي من خير ما يحتسب"
        },
        {
          "verse_index": 6,
          "text": "وقامت يهود بأسيافها  قصار الجود لئام الحسب"
        },
        {
          "verse_index": 7,
          "text": "عبيد أبي كربٍ تبعٍ  عبيدٌ قصارٌ دقاق النسب"
        }
      ]
    },
    {
      "poem_index": 3,
      "poem_id": "hind_bt_ʿutbah_003",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "يريب علينا الدهر فيسوءنا  ويأبى فما نأتي بشيء يغالبه"
        },
        {
          "verse_index": 1,
          "text": "أبعد قتيل من لؤي بن غالب  يراع أمرؤ إن مات أو مات صاحبه"
        },
        {
          "verse_index": 2,
          "text": "ألا رب يوم قد رزئت مرزأً  تروح وتغدو بالجزيل مواهبه"
        },
        {
          "verse_index": 3,
          "text": "فأبلغ أبا سفيان عني مألكاً  فإن ألقه يوماً فسوف أعاتبه"
        },
        {
          "verse_index": 4,
          "text": "فقد كان حرب يسعر الحرب إنه  لكل امرىء في الناس مولى يطالبه"
        }
      ]
    },
    {
      "poem_index": 4,
      "poem_id": "hind_bt_ʿutbah_004",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "أبكي عميدالأبطحينكليهما  وحاميهما من كل باغٍ يريدها"
        },
        {
          "verse_index": 1,
          "text": "أبي عتبة الخيرات ويحك فاعلمي  وشيبة والحامي الذمار وليدها"
        },
        {
          "verse_index": 2,
          "text": "أولئك آل المجد من آل غالبٍ  وفي العز منها حين ينمي عديدها"
        }
      ]
    },
    {
      "poem_index": 5,
      "poem_id": "hind_bt_ʿutbah_005",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "شفيت من حمزة نفسي بأحد  حتى بقرت بطنه عن الكبد"
        },
        {
          "verse_index": 1,
          "text": "أذهب عني ذاك ما كنت أجد  من لذعة الحزن الشديد المعتمد"
        },
        {
          "verse_index": 2,
          "text": "والحرب تعلوكم بشؤبوب برد  تقدم إقداماً عليكم كالأسد"
        }
      ]
    },
    {
      "poem_index": 6,
      "poem_id": "hind_bt_ʿutbah_006",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "نحن جزيناكم بيوم بدر  والحرب بعد الحرب ذات سعر"
        },
        {
          "verse_index": 1,
          "text": "ما كان عن عتبة لي من صبر  ولا أخي وعمه وبكري"
        },
        {
          "verse_index": 2,
          "text": "شفيت نفسي وقضيت نذري  شفيت وحشي غليل صدري"
        },
        {
          "verse_index": 3,
          "text": "فشكر وحشي على عمري  حتى ترم أعظمي في قبري"
        },
        {
          "verse_index": 4,
          "text": "أبي وعمي وشقيق بكري  أخي الذي كان كضوء البدر"
        },
        {
          "verse_index": 5,
          "text": "بهم كسرت يا علي ظهري"
        }
      ]
    },
    {
      "poem_index": 7,
      "poem_id": "hind_bt_ʿutbah_007",
      "meter": "بحر منهوك المنسرح",
      "verses": [
        {
          "verse_index": 0,
          "text": "إيهاً بني عبد الدار  أيها حماة الأدبار"
        },
        {
          "verse_index": 1,
          "text": "ضرباً بكل بتار"
        }
      ]
    },
    {
      "poem_index": 8,
      "poem_id": "hind_bt_ʿutbah_008",
      "meter": "بحر مجزوء الرجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "نحن بناتطارق  نمشيعلىالنمارق"
        },
        {
          "verse_index": 1,
          "text": "مشيالقطاالموانق  قيدي مع المفارق"
        },
        {
          "verse_index": 2,
          "text": "ومن أبى نفارق  إن تقبلوا نعانق"
        },
        {
          "verse_index": 3,
          "text": "أو تدبروا نفارق  فراق غير وامق"
        },
        {
          "verse_index": 4,
          "text": "هل من كريم عاشق  يحمي عن العوانق"
        },
        {
          "verse_index": 5,
          "text": "والمسك في المفارق  والدر في المخانق"
        }
      ]
    },
    {
      "poem_index": 9,
      "poem_id": "hind_bt_ʿutbah_009",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "أفي السلم أعيار جفاء وغلظة  وفي الحرب أشباه النساء العوارك"
        }
      ]
    },
    {
      "poem_index": 10,
      "poem_id": "hind_bt_ʿutbah_010",
      "meter": "بحر مجزوء الكامل",
      "verses": [
        {
          "verse_index": 0,
          "text": "من حس لي الأخوين كال  غصنين أو من راهما"
        },
        {
          "verse_index": 1,
          "text": "قرمان لا يتظالما  ن ولا يرام حماهما"
        },
        {
          "verse_index": 2,
          "text": "ويلي على أبوي وال  قبر الذي واراهما"
        },
        {
          "verse_index": 3,
          "text": "لا مثل كهلي في الكهو  ل ولا فتىً كفتاهما"
        },
        {
          "verse_index": 4,
          "text": "أسدان لا يتذللا  ن ولا يرام حماهما"
        },
        {
          "verse_index": 5,
          "text": "رمحين خطيين في  كبد السماء تراهما"
        },
        {
          "verse_index": 6,
          "text": "ما خلفا إذ ودعا  في سدودٍ شرواهما"
        },
        {
          "verse_index": 7,
          "text": "سادا بغير تكلفٍ  عفواً يفيض نداهما"
        },
        {
          "verse_index": 8,
          "text": "سيفين هنديين  سن القبر حد ظباهما"
        },
        {
          "verse_index": 9,
          "text": "ابني ربيعة لا يمل الن  اس من ذكراهما"
        }
      ]
    },
    {
      "poem_index": 11,
      "poem_id": "hind_bt_ʿutbah_011",
      "meter": "بحر مجزوء الكامل",
      "verses": [
        {
          "verse_index": 0,
          "text": "لله عينا من رأى  هلكاً كهلك رجاليه"
        },
        {
          "verse_index": 1,
          "text": "يا رب باك لي غدا  في النائبات وباكيه"
        },
        {
          "verse_index": 2,
          "text": "كم غادروا يوم القليب  غداة تلك الواعيه"
        },
        {
          "verse_index": 3,
          "text": "من كل غيث في السنين  إذا الكواكب خاويه"
        },
        {
          "verse_index": 4,
          "text": "قد كنت أحذر ما أرى  فاليوم حق حذاريه"
        },
        {
          "verse_index": 5,
          "text": "قد كنت أحذر ما أرى  فأنا الغداة مواميه"
        },
        {
          "verse_index": 6,
          "text": "يا رب قائلة غداً  يا ويح أم معاويه"
        }
      ]
    },
    {
      "poem_index": 12,
      "poem_id": "hind_bt_ʿutbah_012",
      "meter": "بحر مجزوء الرجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "يا عين بكي عتبه  شيخاً شديد الرقبه"
        },
        {
          "verse_index": 1,
          "text": "يطعم يوم المسغبه  يدفع يوم المغلبه"
        },
        {
          "verse_index": 2,
          "text": "إني عليه حربه  ملهوفة مستلبه"
        },
        {
          "verse_index": 3,
          "text": "لنهبطن يثربه  بغارة منثعبه"
        },
        {
          "verse_index": 4,
          "text": "فيها الخيول مقربه  كل جواد سلهبه"
        }
      ]
    },
    {
      "poem_index": 13,
      "poem_id": "hind_bt_ʿutbah_013",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إن بني معرقٌ كريم  محببٌ في أهله حليم"
        },
        {
          "verse_index": 1,
          "text": "ليس بفحاش ولا لئيم  ولا بطخرور ولا سؤوم"
        },
        {
          "verse_index": 2,
          "text": "صخر بني فهرٍ به زعيم  لا يخلف الظن ولا يخيم"
        }
      ]
    },
    {
      "poem_index": 14,
      "poem_id": "hind_bt_ʿutbah_014",
      "meter": "بحر منهوك المنسرح",
      "verses": [
        {
          "verse_index": 0,
          "text": "صبراً بني عبد الدار  صبراً حماة الأديار"
        },
        {
          "verse_index": 1,
          "text": "ضرباً بكل بتَّار"
        }
      ]
    },
    {
      "poem_index": 15,
      "poem_id": "hind_bt_ʿutbah_015",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "إن بُني من رجال الحمس  كريم أصل وكريم نفس"
        },
        {
          "verse_index": 1,
          "text": "ليس بوجّاب الفؤاد نكس  عتبة بدر وأبوه شمس"
        }
      ]
    },
    {
      "poem_index": 16,
      "poem_id": "hind_bt_ʿutbah_016",
      "meter": "بحر مجزوء الرجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "راقص فدتك نفسي  لآل عبد شمس"
        },
        {
          "verse_index": 1,
          "text": "فهم سراة الحمس  على قديم الحرس"
        }
      ]
    },
    {
      "poem_index": 17,
      "poem_id": "hind_bt_ʿutbah_017",
      "meter": "وافر",
      "verses": [
        {
          "verse_index": 0,
          "text": "لحاها الله صابئة بوجٍ  ومكة عند أطراف الحجون"
        },
        {
          "verse_index": 1,
          "text": "تدين لمعشر قتلوا أباها  أقتل أبيك جاءك باليقين"
        }
      ]
    },
    {
      "poem_index": 18,
      "poem_id": "hind_bt_ʿutbah_018",
      "meter": "بسيط",
      "verses": [
        {
          "verse_index": 0,
          "text": "الأحول الأثعل المشؤوم طائره  أبو حذيفة شر الناس في الدين"
        },
        {
          "verse_index": 1,
          "text": "أما شمرت أباً رباك من صغرٍ  حتى شببت شباباً غير محجون"
        }
      ]
    }
  ]
}