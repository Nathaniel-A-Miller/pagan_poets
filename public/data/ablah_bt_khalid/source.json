      "verses": [
        {
          "verse_index": 0,
          "text": "شَرِبْتُ بِراحِلَتَيْ مِحْجَنٍ  فَيا وَيْلَتِي مِحْجَنٌ قاتِلِي"
        },
        {
          "verse_index": 1,
          "text": "وَبِابْنِ أَخِيهِ عَلَى لَذَّةٍ  وَلَمْ أَحْتَفِلْ عَذْلَةَ الْعاذِلِ"
        }
      ]
    }
  ]
