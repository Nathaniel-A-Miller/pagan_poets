        "verse_indices": [
          65
        ],
        "category": "Cosmological_Concepts",
        "entity_or_term": "الدَهرَ",
        "notes": "The term 'al-Dahr' (Time/Fate) represents a pre-Islamic cosmological concept of an impersonal, irresistible force that governs events and destiny."
      },
      {
