  "poems": [
    {
      "poem_index": 0,
      "poem_id": "al-ashʿar_al-balawī_000",
      "meter": "وافر",
      "verses": [
        {
          "verse_index": 0,
          "text": "هُمُ مَلَؤُوا الْمَسِيلَ مَسِيلَ نَجْدٍ  وَغَصَّمَضِيقُهُ بِهِمُ طَوِيلا"
        },
        {
          "verse_index": 1,
          "text": "وَعِنْدِي الْعِلْمُ أَنَّ الْقَوْمَ زادُوا  عَلَى مِئَتَيْنِ أَوْ نَقَصُوا قَلِيلا"
        },
        {
          "verse_index": 2,
          "text": "فَإِنْ يَكُ ذُو الشَّلِيلِ نَجا صَحِيحاً  فَلا تَحْمَدْ لَهُ إِلَّا الشَّلِيلا"
        }
      ]
    }
  ]
}