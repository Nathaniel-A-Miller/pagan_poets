{
  "poet": {
    "name_ar": "أميمة أم تأبط شرا",
    "name_en": "Umaymah Umm Taʾabbaṭa Sharran",
    "tribe": "Qayn",
    "region": "Hijaz",
    "chronological_layer": "pre-Islamic",
    "gender": "female",
    "number_of_lines": 14,
    "metadata_notes": ""
  },
  "poems": [
    {
      "poem_index": 0,
      "poem_id": "umaymah_umm_taʾabbaṭa_sharran_000",
      "meter": "رجز",
      "verses": [
        {
          "verse_index": 0,
          "text": "بِثابِتِ بْنِ جابِرِ بْنِ سُفْيانْ  نِعْمَ الْفَتَى غادَرْتُمُ بِرَخْمانْ"
        },
        {
          "verse_index": 1,
          "text": "يَحْدُو وَيَرْوِي ظَمَأَ النَّدْمانْ  رِواءَ مَنْ يَحْمِي حِمَى الْإِخْوانْ"
        }
      ]
    },
    {
      "poem_index": 1,
      "poem_id": "umaymah_umm_taʾabbaṭa_sharran_001",
      "meter": "رمل",
      "verses": [
        {
          "verse_index": 0,
          "text": "طافَ يَبْغِي نَجْوَةً  مِنْ هَلاكٍ فَهَلَكْ"
        },
        {
          "verse_index": 1,
          "text": "لَيْتَ شِعْرِي ضَلَّةً  أَيُّ شَيْءٍ قَتَلَكْ"
        },
        {
          "verse_index": 2,
          "text": "أَمَرِيضٌ لَمْ تُعَدْ  أَمْ عَدُوٌّ خَتَلَكْ"
        },
        {
          "verse_index": 3,
          "text": "أَمْ تَوَلَّى مارِدٌ  غالَ فِي الدَّهْرِ السُّلَكْ"
        },
        {
          "verse_index": 4,
          "text": "وَالْمَنايا رُصَّدٌ  لِلْفَتَى حَيْثُ سَلَكْ"
        },
        {
          "verse_index": 5,
          "text": "أَيُّ شَيْءٍ حَسَنٍ  لِفَتىً لَمْ يَكُ لَكْ"
        },
        {
          "verse_index": 6,
          "text": "كُلُّ شَيْءٍ قاتِلٌ  حِينَ تَلْقَى أَجَلَكْ"
        },
        {
          "verse_index": 7,
          "text": "طالَما قَدْ نِلْتَ فِي  غَيْرِ كَدٍّ أَمْلَكْ"
        },
        {
          "verse_index": 8,
          "text": "إِنَّ أَمْراً فادِحاً  عَنْ جَوابِي شغَلَكْ"
        },
        {
          "verse_index": 9,
          "text": "سَأُعَزِّي النَّفْسَ إِذْ  لَمْ تُجِبْ مَنْ سَأَلَكْ"
        },
        {
          "verse_index": 10,
          "text": "لَيْتَ قَلْبِي ساعَةً  صَبْرَهُ عَنْكَ مَلَكْ"
        },
        {
          "verse_index": 11,
          "text": "لَيْتَ نَفْسِي قُدِّمَتْ  لِلْمَنايا بَدَلَكْ"
        }
      ]
    }
  ]
}