  "poems": [
    {
      "poem_index": 0,
      "poem_id": "hind_bt_ibn_ʿāmir_al-aslamī_000",
      "meter": "وافر",
      "verses": [
        {
          "verse_index": 0,
          "text": "لقد أرسلت ليلى أثر هند  فلم أدرك بذلك من نصيب"
        },
        {
          "verse_index": 1,
          "text": "لعمرك ما ابنة السلمى ليلى  بفاحشة المحل ولا كذوب"
        },
        {
          "verse_index": 2,
          "text": "ولا مشأة في يوم ريح  تحدث عن أحاديث المعيب"
        }
      ]
    }
  ]
}