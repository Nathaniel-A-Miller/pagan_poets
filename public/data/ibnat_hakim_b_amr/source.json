{
  "poet": {
    "name_ar": "ابنة حكيم بن عمرو",
    "name_en": "Ibnat Ḥakīm b. ʿAmr",
    "tribe": "ʿAbd al-Qays",
    "region": "Najd",
    "chronological_layer": "pre-Islamic",
    "gender": "female",
    "number_of_lines": 4,
    "metadata_notes": ""
  },
  "poems": [
    {
      "poem_index": 0,
      "poem_id": "ibnat_ḥakīm_b_ʿamr_000",
      "meter": "طويل",
      "verses": [
        {
          "verse_index": 0,
          "text": "أَيَرجو رَبيعٌ أَن يؤوبَ وَقَد ثَوى  حَكيمٌ وَأَمسى شلوه بمطبّقِ"
        },
        {
          "verse_index": 1,
          "text": "فَإِن كنتمُ قَوماً كِراماً فَعَجّلوا  لَه جُرأةً مِن بأسِكم ذات مصدقِ"
        },
        {
          "verse_index": 2,
          "text": "فَإِن لَم تَنالوا نيلكم بِسُيوفكم  فَكونوا نِساء في الملاء المخلّقِ"
        },
        {
          "verse_index": 3,
          "text": "وَقولوا ربيعٌ ربّكم فَاِسجُدوا له  فَما أَنتمُ إلّا كَمعزى الحبلّقِ"
        }
      ]
    }
  ]
}