      "verses": [
        {
          "verse_index": 0,
          "text": "أَصْبَحَ جَعْدٌ وَأَبُو الْمَوْزُونْ  يَرْمُونَ قَطَّاطِنَ بِالظُّنُونْ"
        },
        {
          "verse_index": 1,
          "text": "ما ساقَ خَمْساً قَبْلَهُ عِنِّينْ  يَسْأَلُ فِي الْمَهْرِ وَيَسْتَدِينْ"
        }
      ]
    }
  ]
